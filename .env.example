# Gemini API
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Airtable
# Create a Personal Access Token at https://airtable.com/create/tokens
# Required scopes: data.records:write, schema.bases:read
# Required access: your "Email Triage" base
AIRTABLE_TOKEN=your_airtable_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Emails

# Slack
# Create an app at https://api.slack.com/apps
# Required scope: chat:write
# Install to workspace and copy the Bot Token (xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL=#n8n-triage

# Gmail OAuth2
# Set up via Google Cloud Console — enable Gmail API,
# create OAuth 2.0 Web Client credentials, add your
# Gmail address as a test user under OAuth consent screen.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
